# ===================================
# Move Market Environment Configuration
# ===================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# ============ Application ============
NODE_ENV=development
APP_NAME="Move Market"
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001
VITE_BACKEND_URL=http://localhost:3001

# ============ Aptos Configuration ============
VITE_APTOS_NETWORK=testnet
VITE_APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1
VITE_APTOS_FAUCET_URL=https://faucet.testnet.aptoslabs.com

# Contract Addresses (update after deployment)
VITE_MARKET_MANAGER_ADDRESS=0x...
VITE_BETTING_MODULE_ADDRESS=0x...
VITE_COLLATERAL_VAULT_ADDRESS=0x...

# Admin wallet
APTOS_ADMIN_PRIVATE_KEY=0x...  # NEVER commit this!
APTOS_ADMIN_ADDRESS=0x...

# ============ USDC Configuration ============
VITE_USDC_CONTRACT_ADDRESS=0x...
USDC_DECIMALS=6

# ============ Oracle Configuration ============
# Pyth Network
VITE_PYTH_CONTRACT_ADDRESS=0x7e783b349d3e89cf5931af376ebeadbfab855b3fa239b7ada8f5a92fbea6b387
PYTH_API_ENDPOINT=https://hermes.pyth.network

# UMA Protocol
UMA_OPTIMISTIC_ORACLE_ADDRESS=0x...
UMA_BOND_AMOUNT=750

# ============ Database (PostgreSQL) ============
DATABASE_URL=postgresql://postgres:password@localhost:5432/prediction_market

# ============ Redis Cache ============
REDIS_URL=redis://localhost:6379

# ============ API Configuration ============
PORT=3000
API_PREFIX=/api/v1

# ============ Compliance & KYC ============
ENABLE_GEOFENCING=true
BLOCKED_COUNTRIES=US,SG,BE,FR,PL
KYC_PROVIDER=persona
KYC_API_KEY=your_kyc_api_key

# ============ Feature Flags ============
FEATURE_ORACLE_RESOLUTION=true

# ============ Sui Configuration ============
VITE_SUI_NETWORK=testnet
VITE_SUI_PACKAGE_ID=0x...
VITE_SUI_TREASURY_ID=0x...
VITE_SUI_USDC_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC

FEATURE_SOCIAL_TRADING=false
