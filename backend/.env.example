# ================================
# APPLICATION
# ================================

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Active blockchain chains (comma-separated: base, aptos, sui, movement)
# Only the specified chains will be indexed
ACTIVE_CHAINS=base

# ================================
# SECURITY
# ================================

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173

# Wallet signature TTL in milliseconds (default: 5 minutes)
SIGNATURE_TTL_MS=300000

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ================================
# DATABASE
# ================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/based

# Redis (optional - for distributed rate limiting)
# REDIS_URL=redis://localhost:6379

# ================================
# BASE BLOCKCHAIN (Primary)
# ================================

BASE_RPC_URL=https://sepolia.base.org
BASE_WS_URL=wss://sepolia.base.org
BASE_CHAIN_ID=84532

# Contract addresses (deployed to Base Sepolia)
MARKET_FACTORY_ADDRESS=0x51baebd534f1b56003dcf11587874f9c9fa6f41a
AMM_ADDRESS=0x5c775990facaddcc608a7770f78a8e57f401b93e
UMA_ADAPTER_ADDRESS=0x...
PYTH_ADAPTER_ADDRESS=0x...
CONDITIONAL_TOKENS_ADDRESS=0xaf64d3778a5c065499e2ce22bf94d949ea353c87
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# External protocol addresses (Base Sepolia)
PYTH_CONTRACT_ADDRESS=0xA2aa501b19aff244D90cc15a4Cf739D2725B5729
# UMA_OOV3_ADDRESS=0x0F7fC5E6482f096380db6158f978167b57388deE

# Wallet private keys (keeper operations)
ADMIN_PRIVATE_KEY=0x...
KEEPER_PRIVATE_KEY=0x...
RESOLVER_PRIVATE_KEY=0x...

# ================================
# AI AGENTS (Optional)
# ================================

AGENT_ENABLED=false
AGENT_AUTO_RESOLVE=false
AGENT_AUTO_DISPUTE=false
AGENT_COMMENTARY_ENABLED=false
AGENT_CONFIDENCE_THRESHOLD=80
AGENT_DISPUTE_CONFIDENCE_THRESHOLD=90
ANTHROPIC_API_KEY=sk-ant-...
