# ================================
# APPLICATION
# ================================

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Active blockchain chains (comma-separated: aptos, sui, movement)
# Only the specified chains will be indexed
ACTIVE_CHAINS=aptos

# ================================
# SECURITY
# ================================

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173

# Wallet signature TTL in milliseconds (default: 5 minutes)
SIGNATURE_TTL_MS=300000

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ================================
# DATABASE
# ================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aptospredict

# Redis (optional - for distributed rate limiting)
# REDIS_URL=redis://localhost:6379

# ================================
# APTOS BLOCKCHAIN (Required)
# ================================

APTOS_NETWORK=testnet
APTOS_MODULE_ADDRESS=0x...
APTOS_EXPECTED_CHAIN_ID=2

# Admin account (optional - for backend blockchain operations)
# APTOS_ADMIN_ACCOUNT=0x...
# APTOS_ADMIN_PRIVATE_KEY=...

# ================================
# SUI BLOCKCHAIN (Optional)
# ================================
# Only required if using Sui chain
# Backend will start without these if only using Aptos

# Set to 'true' to completely disable SUI indexer (even if SUI_PACKAGE_ID is set)
# This prevents unnecessary RPC calls and reduces resource usage when only using Aptos
DISABLE_SUI_INDEXER=false

SUI_RPC_URL=https://fullnode.testnet.sui.io
# SUI_PACKAGE_ID=0x...
# SUI_ADMIN_PRIVATE_KEY=
# SUI_ADMIN_CAP_ID=0x...
# SUI_TREASURY_ID=0x...
SUI_EXPECTED_CHAIN_ID=35834a8a
SUI_USDC_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC

MOVEMENT_EXPECTED_CHAIN_ID=movement-testnet
