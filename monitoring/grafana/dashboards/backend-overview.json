{
  "id": null,
  "uid": "backend-overview",
  "title": "Backend Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests (req/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "rate(based_http_requests_total[1m])",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Latency (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(based_http_request_duration_seconds_bucket[5m])) by (le, route)) * 1000",
          "legendFormat": "{{route}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    },
    {
      "type": "stat",
      "title": "Rate Limit Hits (HTTP 429)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "sum(increase(based_http_requests_total{status=\"429\"}[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 }
    },
    {
      "type": "stat",
      "title": "HTTP Errors (5xx)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "sum(increase(based_http_requests_total{status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 }
    },
    {
      "type": "stat",
      "title": "Healthy Responses (2xx)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "sum(increase(based_http_requests_total{status=~\"2..\"}[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "Settlement Executions per Minute",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "rate(based_settlement_executions_total[5m]) * 60",
          "legendFormat": "{{chain}} {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "Settlement Batch Size",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(based_settlement_batch_request_bucket[5m])) by (le, chain))",
          "legendFormat": "{{chain}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(based_settlement_batch_request_bucket[5m])) by (le, chain))",
          "legendFormat": "{{chain}} p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 }
    },
    {
      "type": "stat",
      "title": "Claim Tickets Built (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "sum(increase(based_claim_ticket_build_total[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 36 }
    },
    {
      "type": "timeseries",
      "title": "Sui Indexer Polls per Minute",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "rate(based_sui_indexer_polls_total[5m]) * 60",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 8, "y": 36 }
    },
    {
      "type": "timeseries",
      "title": "Sui Events Processed per Minute",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "rate(based_sui_events_processed_total[5m]) * 60",
          "legendFormat": "Events processed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 20, "y": 36 }
    },
    {
      "type": "timeseries",
      "title": "Market Resolution Success Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "rate(based_market_resolution_total{result=\"success\"}[5m]) / rate(based_market_resolution_total[5m]) * 100",
          "legendFormat": "{{chain}} success rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 }
    },
    {
      "type": "stat",
      "title": "Sui Indexer Health",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "increase(based_sui_indexer_polls_total{result=\"success\"}[15m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 52 }
    },
    {
      "type": "stat",
      "title": "Sui Settlement Queue Size",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "based_settlement_queue_size{chain=\"sui\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 52 }
    },
    {
      "type": "stat",
      "title": "Active Sui Markets",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "targets": [
        {
          "expr": "based_active_markets{chain=\"sui\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 52 }
    }
  ]
}
