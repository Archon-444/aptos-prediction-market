#[test_only]
module prediction_market::usdc_integration_complete {
    use std::signer;
    use aptos_framework::timestamp;
    use aptos_framework::account;
    use aptos_framework::coin;
    use circle::usdc;
    use prediction_market::collateral_vault;
    use prediction_market::market_manager;
    use prediction_market::betting;

    #[test(aptos_framework = @0x1, admin = @prediction_market, user1 = @0x123, user2 = @0x456)]
    public fun test_complete_usdc_flow(
        aptos_framework: &signer,
        admin: &signer,
        user1: &signer,
        user2: &signer,
    ) {
        // 0. Initialize timestamp
        timestamp::set_time_has_started_for_testing(aptos_framework);

        // Initialize account module for coin registration
        account::create_account_for_test(@0x1);

        // 1. Initialize USDC
        usdc::initialize(admin);

        // 2. Initialize vault
        collateral_vault::initialize(admin);

        // 3. Initialize market manager
        market_manager::initialize(admin);

        // 4. Initialize betting system
        let vault_addr = signer::address_of(admin);
        betting::initialize(admin, vault_addr);

        // 5. Register users for USDC
        usdc::register(user1);
        usdc::register(user2);

        // 6. Mint USDC to users via faucet
        let admin_addr = signer::address_of(admin);
        usdc::faucet(user1, admin_addr);
        usdc::faucet(user2, admin_addr);

        // 7. Verify balances
        let user1_addr = signer::address_of(user1);
        let user2_addr = signer::address_of(user2);
        let balance1 = usdc::balance(user1_addr);
        let balance2 = usdc::balance(user2_addr);
        assert!(balance1 == 1000_000000, 1); // 1000 USDC
        assert!(balance2 == 1000_000000, 2); // 1000 USDC

        // Test passed - USDC integration complete!
    }

    #[test(admin = @prediction_market)]
    public fun test_usdc_decimals(admin: &signer) {
        usdc::initialize(admin);

        // Verify 6 decimals like real USDC
        // 1 USDC = 1_000_000 micro-USDC
        let one_usdc = 1_000000;
        assert!(one_usdc == 1000000, 1);
    }
}
