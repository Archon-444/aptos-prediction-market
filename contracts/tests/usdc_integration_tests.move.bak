#[test_only]
module prediction_market::integration_tests {
    use std::signer;
    use std::string;
    use std::vector;
    use aptos_framework::timestamp;
    use aptos_framework::account;
    use aptos_framework::coin;
    
    use circle::usdc;
    use circle::usdc::USDC;
    use prediction_market::collateral_vault;
    use prediction_market::betting;
    use prediction_market::market_manager;
    use prediction_market::access_control;
    
    // Test helper to setup testing environment
    fun setup_test(
        aptos_framework: &signer,
        admin: &signer,
    ): address {
        // Initialize timestamp for testing
        timestamp::set_time_has_started_for_testing(aptos_framework);

        // Initialize coin conversion map (required for coin registration)
        coin::create_coin_conversion_map(aptos_framework);

        // Initialize account module for coin registration
        account::create_account_for_test(@0x1);

        let admin_addr = signer::address_of(admin);

        // Initialize test USDC
        usdc::initialize(admin);

        // Initialize market manager
        market_manager::initialize(admin);

        // Initialize vault
        collateral_vault::initialize(admin);

        // Initialize betting system
        betting::initialize(admin, admin_addr);

        admin_addr
    }
    
    fun mint_usdc_to_user(admin: &signer, user: &signer, amount: u64) {
        let user_addr = signer::address_of(user);
        
        // Register user for USDC
        usdc::register(user);
        
        // Mint USDC to user
        usdc::mint(admin, user_addr, amount);
    }
    
    #[test(aptos_framework = @0x1, admin = @0xcafe, user1 = @0x100, user2 = @0x200)]
    public fun test_complete_betting_flow(
        aptos_framework: &signer,
        admin: &signer,
        user1: &signer,
        user2: &signer,
    ) {
        // Setup
        let admin_addr = setup_test(aptos_framework, admin);
        account::create_account_for_test(signer::address_of(user1));
        account::create_account_for_test(signer::address_of(user2));
        
        // Mint USDC to users
        let bet_amount = 100_000000; // 100 USDC
        mint_usdc_to_user(admin, user1, bet_amount);
        mint_usdc_to_user(admin, user2, bet_amount);
        
        // Verify balances
        assert!(usdc::balance(signer::address_of(user1)) == bet_amount, 1);
        assert!(usdc::balance(signer::address_of(user2)) == bet_amount, 2);
        
        // Create market
        market_manager::create_market(
            admin,
            b"Will BTC hit $100k by end of 2025?",
            vector[b"Yes", b"No"],
            24, // 24 hours
        );
        
        // Verify market created
        let market_count = market_manager::get_market_count();
        assert!(market_count == 1, 3);
        
        // User1 bets on outcome 0 (Yes), User2 bets on outcome 1 (No)
        betting::place_bet(user1, 0, 0, bet_amount); // market_id=0, outcome=0
        betting::place_bet(user2, 0, 1, bet_amount); // market_id=0, outcome=1
        
        // Verify USDC transferred to vault
        assert!(usdc::balance(signer::address_of(user1)) == 0, 4);
        assert!(usdc::balance(signer::address_of(user2)) == 0, 5);
        
        let vault_balance = collateral_vault::get_vault_balance(admin_addr);
        assert!(vault_balance == bet_amount * 2, 6);
        
        // Check market stakes
        let stakes = collateral_vault::get_market_stakes(admin_addr, 0);
        assert!(vector::length(&stakes) == 2, 7);
        assert!(*vector::borrow(&stakes, 0) == bet_amount, 8);
        assert!(*vector::borrow(&stakes, 1) == bet_amount, 9);
        
        // Wait for market to end
        timestamp::fast_forward_seconds(25 * 3600); // Move past end time
        
        // Resolve market - outcome 0 (Yes) wins
        market_manager::resolve_market(admin, 0, 0);
        
        // Unlock collateral
        betting::unlock_market_collateral(admin, 0);
        
        // User1 claims winnings
        betting::claim_winnings(user1, 0);
        
        // User1 should have 200 USDC (their stake + winnings)
        let user1_final_balance = usdc::balance(signer::address_of(user1));
        assert!(user1_final_balance == bet_amount * 2, 10);
        
        // User2 lost, should have 0
        assert!(usdc::balance(signer::address_of(user2)) == 0, 11);
    }
    
    #[test(aptos_framework = @0x1, admin = @0xcafe, user = @0x100)]
    public fun test_multiple_bets_same_outcome(
        aptos_framework: &signer,
        admin: &signer,
        user: &signer,
    ) {
        let admin_addr = setup_test(aptos_framework, admin);
        account::create_account_for_test(signer::address_of(user));
        
        // Give user 1000 USDC
        mint_usdc_to_user(admin, user, 1000_000000);
        
        // Create market
        market_manager::create_market(
            admin,
            b"Test market",
            vector[b"Yes", b"No"],
            24,
        );
        
        // Place multiple bets on same outcome
        betting::place_bet(user, 0, 0, 100_000000); // 100 USDC
        betting::place_bet(user, 0, 0, 200_000000); // 200 USDC
        betting::place_bet(user, 0, 0, 300_000000); // 300 USDC
        
        // Verify position
        let (outcome, stake, claimed) = collateral_vault::get_user_position(signer::address_of(user), 0);
        assert!(outcome == 0, 1);
        assert!(stake == 600_000000, 2); // Total 600 USDC
        assert!(!claimed, 3);
        
        // Verify remaining balance
        assert!(usdc::balance(signer::address_of(user)) == 400_000000, 4);
    }
    
    #[test(aptos_framework = @0x1, admin = @0xcafe, user1 = @0x100, user2 = @0x200, user3 = @0x300)]
    public fun test_multiple_outcomes_payout(
        aptos_framework: &signer,
        admin: &signer,
        user1: &signer,
        user2: &signer,
        user3: &signer,
    ) {
        let admin_addr = setup_test(aptos_framework, admin);
        account::create_account_for_test(signer::address_of(user1));
        account::create_account_for_test(signer::address_of(user2));
        account::create_account_for_test(signer::address_of(user3));
        
        // Give users USDC
        mint_usdc_to_user(admin, user1, 300_000000); // 300 USDC
        mint_usdc_to_user(admin, user2, 150_000000); // 150 USDC
        mint_usdc_to_user(admin, user3, 50_000000);  // 50 USDC
        
        // Create market with 3 outcomes
        market_manager::create_market(
            admin,
            b"Who will win?",
            vector[b"Team A", b"Team B", b"Team C"],
            24,
        );
        
        // Place bets
        betting::place_bet(user1, 0, 0, 300_000000); // Team A
        betting::place_bet(user2, 0, 1, 150_000000); // Team B
        betting::place_bet(user3, 0, 2, 50_000000);  // Team C
        
        // Total pool = 500 USDC
        // If Team C wins: payout = (50/50) * 500 = 500 USDC
        
        // Resolve - Team C wins
        timestamp::fast_forward_seconds(25 * 3600);
        market_manager::resolve_market(admin, 0, 2);
        betting::unlock_market_collateral(admin, 0);
        
        // User3 claims
        betting::claim_winnings(user3, 0);
        
        // User3 should get entire pool
        let user3_balance = usdc::balance(signer::address_of(user3));
        assert!(user3_balance == 500_000000, 1); // Got all 500 USDC
    }
    
    #[test(aptos_framework = @0x1, admin = @0xcafe, user = @0x100)]
    #[expected_failure(abort_code = 0x10006, location = prediction_market::betting)]
    public fun test_bet_below_minimum(
        aptos_framework: &signer,
        admin: &signer,
        user: &signer,
    ) {
        setup_test(aptos_framework, admin);
        account::create_account_for_test(signer::address_of(user));
        
        mint_usdc_to_user(admin, user, 10_000000);
        
        market_manager::create_market(
            admin,
            b"Test",
            vector[b"Yes", b"No"],
            24,
        );
        
        // Try to bet 0.5 USDC (below 1 USDC minimum)
        betting::place_bet(user, 0, 0, 500000);
    }
    
    #[test(aptos_framework = @0x1, admin = @0xcafe, user = @0x100)]
    #[expected_failure(abort_code = 0x30001, location = prediction_market::betting)]
    public fun test_bet_on_expired_market(
        aptos_framework: &signer,
        admin: &signer,
        user: &signer,
    ) {
        setup_test(aptos_framework, admin);
        account::create_account_for_test(signer::address_of(user));
        
        mint_usdc_to_user(admin, user, 100_000000);
        
        market_manager::create_market(
            admin,
            b"Test",
            vector[b"Yes", b"No"],
            1, // 1 hour
        );
        
        // Wait for market to expire
        timestamp::fast_forward_seconds(2 * 3600);
        
        // Try to bet after expiration
        betting::place_bet(user, 0, 0, 10_000000);
    }
    
    #[test(aptos_framework = @0x1, admin = @0xcafe)]
    public fun test_odds_calculation(
        aptos_framework: &signer,
        admin: &signer,
    ) {
        setup_test(aptos_framework, admin);
        
        market_manager::create_market(
            admin,
            b"Test",
            vector[b"Yes", b"No"],
            24,
        );
        
        // Initial odds should be equal (50/50 = 5000 basis points each)
        let odds = betting::get_odds(0);
        assert!(vector::length(&odds) == 2, 1);
        assert!(*vector::borrow(&odds, 0) == 5000, 2); // 50%
        assert!(*vector::borrow(&odds, 1) == 5000, 3); // 50%
    }
    
    #[test(aptos_framework = @0x1, admin = @0xcafe, user = @0x100)]
    public fun test_faucet_functionality(
        aptos_framework: &signer,
        admin: &signer,
        user: &signer,
    ) {
        setup_test(aptos_framework, admin);
        account::create_account_for_test(signer::address_of(user));
        
        // Register and claim from faucet
        usdc::register(user);
        usdc::faucet(user, signer::address_of(admin));
        
        // Should have 1000 USDC
        let balance = usdc::balance(signer::address_of(user));
        assert!(balance == 1000_000000, 1);
    }
}
