# ================================
# BLOCKCHAIN CONFIGURATION
# ================================

# Aptos Configuration (Required for Aptos chain)
VITE_APTOS_MODULE_ADDRESS=0xb2329b6b3270c2577393cbe937de53f933545e29942331f452574f6afbd2d894
VITE_APTOS_USDC_ADDRESS=
VITE_APTOS_NETWORK=testnet

# Sui Configuration (Optional - only needed for Sui chain)
# Uncomment and configure if using Sui
# VITE_SUI_PACKAGE_ID=0x...
# VITE_SUI_TREASURY_ID=0x...
# VITE_SUI_NETWORK=testnet

# Active Chains (comma-separated: 'aptos', 'sui', or 'aptos,sui')
VITE_ACTIVE_CHAINS=aptos

# ================================
# API CONFIGURATION
# ================================

VITE_API_URL=/api

# ================================
# FEATURE FLAGS
# ================================

VITE_ENABLE_PUSH_NOTIFICATIONS=false
VITE_ENABLE_BIOMETRIC_AUTH=false
VITE_ENABLE_SERVICE_WORKER=false

# Push Notifications (optional - requires backend setup)
# VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ================================
# LOGGING
# ================================

# Options: DEBUG, INFO, WARN, ERROR
# VITE_LOG_LEVEL=INFO
