# ================================
# BASE BLOCKCHAIN (Primary)
# ================================

VITE_BASE_CHAIN_ID=84532
VITE_BASE_RPC_URL=https://sepolia.base.org

# Contract addresses (deployed to Base Sepolia)
VITE_FACTORY_ADDRESS=0x51baebd534f1b56003dcf11587874f9c9fa6f41a
VITE_AMM_ADDRESS=0x5c775990facaddcc608a7770f78a8e57f401b93e
VITE_CONDITIONAL_TOKENS_ADDRESS=0xaf64d3778a5c065499e2ce22bf94d949ea353c87
VITE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Base Mainnet contract addresses (set when deploying to mainnet)
VITE_MAINNET_FACTORY_ADDRESS=
VITE_MAINNET_AMM_ADDRESS=
VITE_MAINNET_CONDITIONAL_TOKENS_ADDRESS=
VITE_MAINNET_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
VITE_BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Coinbase Smart Wallet — gasless transactions (optional)
# Get from https://portal.cdp.coinbase.com
VITE_CDP_PAYMASTER_URL=
VITE_CDP_CLIENT_API_KEY=

# ================================
# API CONFIGURATION
# ================================

VITE_API_URL=http://localhost:4000/api
VITE_WS_URL=ws://localhost:4000/ws

# ================================
# WALLET INTEGRATION
# ================================

# WalletConnect v2 project ID — get from https://cloud.walletconnect.com
# Required to enable mobile wallet pairing
VITE_WALLETCONNECT_PROJECT_ID=

# Coinbase OnchainKit App ID (optional)
VITE_BASE_ONCHAINKIT_APP_ID=

# ================================
# FEATURE FLAGS
# ================================

VITE_ENABLE_PUSH_NOTIFICATIONS=false
VITE_ENABLE_BIOMETRIC_AUTH=false
VITE_ENABLE_SERVICE_WORKER=false

# ================================
# LOGGING
# ================================

# Options: DEBUG, INFO, WARN, ERROR
# VITE_LOG_LEVEL=INFO
