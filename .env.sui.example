# Sui Blockchain Configuration
# Copy these to your .env files after deployment

# =============================================================================
# Backend Configuration (backend/.env)
# =============================================================================

# Sui Network RPC URL
# Testnet: https://fullnode.testnet.sui.io:443
# Mainnet: https://fullnode.mainnet.sui.io:443
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Deployed package ID (from deployment script output)
# Get this by running: ./scripts/deploy-sui.sh testnet
SUI_PACKAGE_ID=

# Admin private key in base64 format
# Get this by running: sui keytool export --key-identity <your-key-alias>
# WARNING: Keep this secret! Never commit to git.
SUI_ADMIN_PRIVATE_KEY=

# Optional: Specific capability object IDs (for advanced usage)
SUI_ADMIN_CAP_ID=
SUI_RESOLVER_CAP_ID=
SUI_ROLE_REGISTRY_ID=
SUI_TREASURY_ID=

# =============================================================================
# Frontend Configuration (dapp/.env)
# =============================================================================

# Sui Network (testnet or mainnet)
VITE_SUI_NETWORK=testnet

# Deployed package ID (same as backend)
VITE_SUI_PACKAGE_ID=

# Optional: RPC URL override (if using custom node)
# VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# =============================================================================
# Deployment Instructions
# =============================================================================

# 1. Install Sui CLI
#    brew install sui

# 2. Create and fund account
#    sui client new-address ed25519 prediction-market-testnet
#    sui client faucet

# 3. Deploy contracts
#    ./scripts/deploy-sui.sh testnet

# 4. Copy values from DEPLOYMENT_SUI_testnet.txt to this file

# 5. Export private key
#    sui keytool export --key-identity prediction-market-testnet

# 6. Update .env files with values from above

# =============================================================================
# Verification
# =============================================================================

# Test package is deployed:
#   sui client object $SUI_PACKAGE_ID

# Test backend connection:
#   cd backend && npm run dev
#   Check logs for "Sui client initialized"

# View on explorer:
#   https://suiexplorer.com/object/$SUI_PACKAGE_ID?network=testnet
